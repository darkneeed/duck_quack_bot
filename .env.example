# ----- Telegram -----

# Bot token from @BotFather
BOT_TOKEN=

# Telegram user IDs of moderators, comma-separated
# Example: ADMIN_IDS=123456789,987654321
ADMIN_IDS=

# ID of the supergroup/channel where moderation cards are posted
# For a supergroup the value is negative: -100XXXXXXXXXX
MODERATION_CHAT_ID=

# ID of the topic (thread) inside MODERATION_CHAT_ID
# Set to 0 or 1 if the chat has no topics (General)
MODERATION_TOPIC_ID=0

# ID of the community chat for which invite links are generated
COMMUNITY_CHAT_ID=


# ----- School 21 API -----

# Credentials for the s21-open-api Keycloak client
S21_API_USERNAME=
S21_API_PASSWORD=
S21_CAMPUS_ID=

# Rocket.Chat
RC_BASE_URL=
RC_USER_ID=
RC_AUTH_TOKEN=

# ----- Tuning (optional) -----

# Storage
DB_PATH=data/bot.db

# Topics / notifications
EVENTS_TOPIC_ID=0
WORKSTATION_TOPIC_ID=0
NEWCOMER_TOPIC_ID=0
DIGEST_TOPIC_ID=0
FAILED_AUTH_TOPIC_ID=0
NOTIFY_TOPIC_ID=0

# Feature flags
ENABLE_DIGEST=1
ENABLE_WORKSTATION=1
ENABLE_NEWCOMER=1

# Timing / polling
INVITE_LINK_EXPIRE_SECONDS=86400
PENDING_ALERT_HOURS=0
API_POLL_INTERVAL=120
WORKSTATION_POLL_INTERVAL=
API_DOWN_ALERT_MINUTES=5
REVIEW_NOTIFY_MINUTES=60,15

# S21 API rate limiting
S21_REQUEST_INTERVAL_MS=750
S21_429_BACKOFF_SECONDS=15

# Branding / links / locale
RULES_URL=https://docs.google.com/document/d/1eDYD1tKE7tW7P_8I3k7Bt4F1aknvwed2qweXCcCrFZc/edit?tab=t.0
PLATFORM_BASE_URL=https://platform.21-school.ru
COMMUNITY_NAME=Школы 21
COMMUNITY_CITY=Волгоград
DISPLAY_TIMEZONE=Europe/Moscow

# Commands scope: PRIVATE | PUBLIC | BOTH | OFF
CMD_WHERE_SCOPE=BOTH
CMD_PEERS_SCOPE=BOTH
CMD_LOGTIME_SCOPE=BOTH
CMD_TOP_SCOPE=PUBLIC
CMD_INCAMPUS_SCOPE=PUBLIC
CMD_EVENTS_SCOPE=BOTH
CMD_PROFILE_SCOPE=PRIVATE

# Optional metadata
SUPPORT_CONTACTS=
SOCIAL_TRUST_PROJECT_IDS=
