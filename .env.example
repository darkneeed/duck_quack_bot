# ----- Telegram -----

# Bot token from @BotFather
BOT_TOKEN=

# Telegram user IDs of moderators, comma-separated
# Example: ADMIN_IDS=123456789,987654321
ADMIN_IDS=

# ID of the supergroup/channel where moderation cards are posted
# For a supergroup the value is negative: -100XXXXXXXXXX
MODERATION_CHAT_ID=

# ID of the community chat for which invite links are generated
COMMUNITY_CHAT_ID=


# ----- School 21 API -----

# Credentials for the s21-open-api Keycloak client
S21_API_USERNAME=
S21_API_PASSWORD=
S21_CAMPUS_ID=

# Rocket.Chat
RC_BASE_URL=
RC_USER_ID=
RC_AUTH_TOKEN=

# Runtime-настройки бота больше не задаются через env.
# После первого запуска они хранятся в bot_settings и редактируются через /admin.
# В env остаются только bootstrap-параметры и секреты.

# Storage
DB_PATH=data/bot.db
